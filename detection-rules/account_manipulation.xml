<group name="linux,account_manipulation,privilege_escalation">
 <rule id="100140" level="6">
   <if_group>syslog</if_group>
   <match>useradd</match>
   <description>New user creation detected</description>
 </rule>

 <rule id="100141" level="5">
   <if_group>syslog</if_group>
   <match>usermod</match>
   <description>User modification detected</description>
 </rule>

 <rule id="100142" level="12">
   <if_group>syslog</if_group>
   <match>usermod</match>
    <match>sudo</match>
   <description>User modified and added to sudo group</description>
 </rule>

 <rule id="100143" level="13">
   <if_group>syslog</if_group>
   <match>useradd</match>
    <match>sudo</match>
   <description>New user created and assigned to sudo group</description>
 </rule> 
</group>